{
  "name": "template-repo-mobile-react-native",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "test": "npm run test:unit",
    "test:unit": "jest --config jest.config.js --coverage --ci --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run test:unit",
    "maestro:validate": "tsx ./scripts/validate-maestro-flows.ts",
    "maestro:test": "npm run maestro:validate && maestro test .maestro",
    "maestro:test:android": "npm run maestro:validate && maestro test .maestro/smoke-android.yaml",
    "maestro:test:ios": "npm run maestro:validate && maestro test .maestro/smoke-ios.yaml",
    "test:e2e": "npm run maestro:test",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint . --max-warnings=0 --ignore-pattern coverage/**",
    "start": "react-native start",
    "pods": "npx pod-install --project-directory=ios"
  },
  "dependencies": {
    "@react-navigation/elements": "^2.9.13",
    "@react-navigation/native": "^7.2.1",
    "@react-navigation/native-stack": "^7.14.9",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-gesture-handler": "^2.30.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "^0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "jest": "^29.6.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "lodash": "4.18.1"
  },
  "engines": {
    "node": ">=20"
  }
}
